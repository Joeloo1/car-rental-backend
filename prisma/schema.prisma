generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

generator frontend {
  provider = "prisma-client-js"
  output   = "../frontend/src/types/prisma"
}


datasource db {
  provider = "postgresql"
}



model User {
  id                       String        @id @default(uuid())
  email                    String        @unique
  phoneNumber              String?
  passwordHash             String?
  profileImage             String        @default("default.jpg")
  role                     UserRole      @default(User)
  accountStatus            AccountStatus @default(active)
  isVerified               Boolean       @default(false)
  verifyToken              String?
  verifyTokenExpiry        DateTime?
  passwordResetToken       String?
  passwordResetTokenExpiry DateTime?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt
  passwordChangedAt        DateTime?
  name                     String
  active                   Boolean       @default(true)
  profileImagePublicId     String?
  providerId               String?       @unique
  provider                 Provider?
  address                  Address?
  cars                     Car[]         @relation("LenderCars")
  chatsAsLender            Chat[]        @relation("ChatLender")
  chatsAsUser              Chat[]        @relation("ChatUser")
  messages                 Message[]
  refreshTokens            RefreshToken?
  reviewsRecv              Review[]      @relation("LenderReviews")
  reviewsGiven             Review[]      @relation("UserReviews")
  notifications            Notification[]
  bookings                 Booking[]     @relation("UserBookings")


  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  userId    String   @unique
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Address {
  id        String  @id @default(uuid())
  street    String?
  city      String?
  state     String?
  country   String?
  latitude  Float?
  longitude Float?
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique
  cars Car[]
}

model Car {
  id                 String     @id @default(uuid())
  title              String
  brand              String?
  model              String?
  year               Int?
  description        String?
  pricePerDay        Float
  locationCity       String?
  fuelType           String?
  transmission       String?
  seats              Int?
  topSpeed           Int?
  acceleration       String?
  enginePower        String?
  latitude           Float?
  longitude          Float?
  availabilityStatus CarStatus  @default(available)

  lenderId           String
  categoryId         Int
  createdAt          DateTime   @default(now())
  category           Category   @relation(fields: [categoryId], references: [id])
  lender             User       @relation("LenderCars", fields: [lenderId], references: [id], onDelete: Cascade)
  images             CarImage[]
  chats              Chat[]
  reviews            Review[]
  bookings           Booking[]

  @@index([lenderId])
  @@index([categoryId])
  @@index([availabilityStatus])
  @@index([locationCity])
  @@index([pricePerDay])
}

model Booking {
  id         String        @id @default(uuid())
  userId     String
  carId      String
  startDate  DateTime
  endDate    DateTime
  totalPrice Float
  status     BookingStatus @default(pending)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  user       User          @relation("UserBookings", fields: [userId], references: [id])
  car        Car           @relation(fields: [carId], references: [id])

  @@index([userId])
  @@index([carId])
  @@index([status])
}

model CarImage {
  id        String   @id @default(uuid())
  imageUrl  String
  carId     String
  createdAt DateTime @default(now())
  isMain    Boolean  @default(false)
  order     Int      @default(0)
  publicId  String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
}

model Chat {
  id        String    @id @default(uuid())
  carId     String
  userId    String
  lenderId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  car       Car       @relation(fields: [carId], references: [id], onDelete: Cascade)
  lender    User      @relation("ChatLender", fields: [lenderId], references: [id], onDelete: Cascade)
  user      User      @relation("ChatUser", fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@unique([carId, userId])
  @@index([userId])
  @@index([lenderId])
  @@index([carId])
}

model Message {
  id          String        @id @default(uuid())
  messageText String
  status      MessageStatus @default(sent)
  chatId      String
  senderId    String
  createdAt   DateTime      @default(now())
  chat        Chat          @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId])
  @@index([senderId])
  @@index([createdAt])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  carId     String
  lenderId  String
  userId    String
  createdAt DateTime @default(now())
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  lender    User     @relation("LenderReviews", fields: [lenderId], references: [id])
  user      User     @relation("UserReviews", fields: [userId], references: [id])

  @@unique([carId, userId])
  @@index([carId])
  @@index([lenderId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}


enum UserRole {
  User
  lender
  admin
}

enum AccountStatus {
  active
  suspended
  deleted
}

enum CarStatus {
  available
  rented
  maintenance
  unavailable
}

enum MessageStatus {
  sent
  delivered
  read
}

enum Provider {
  GOOGLE
  LOCAL
}

enum BookingStatus {
  pending
  confirmed
  cancelled
  completed
}
